{
  "$schema": "https://unpkg.com/release-it@20/schema/release-it.json",
  "git": {
    "requireBranch": "dev",
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}",
    "tagAnnotation": "Release ${version}",
    "push": true
  },
  "github": {
    "release": true,
    "preRelease": true,
    "releaseNotes": "node scripts/release-notes.cjs ${version}"
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "after:bump": [
      "node scripts/generate-changelog.cjs ${version} --channel=preview",
      "git add public/changelog.json public/changelog-version.json"
    ]
  }
}
