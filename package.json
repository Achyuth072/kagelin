{
  "name": "kagelin",
  "version": "1.26.2",
  "license": "AGPL-3.0-only",
  "private": false,
  "scripts": {
    "dev": "next dev --turbo",
    "dev:pwa": "next dev --webpack",
    "prebuild": "npm run copy-wasm",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "lint:strict": "eslint src app --max-warnings=13",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "validate": "npm-run-all --parallel format:check lint:strict typecheck test",
    "validate:fix": "npm run format && npm run validate",
    "ci:validate": "cross-env CI=true npm run validate && npm run build",
    "e2e": "playwright test",
    "analyze": "npx cross-env ANALYZE=true npm run build",
    "dead-code": "npx knip",
    "unused-deps": "npx depcheck",
    "copy-wasm": "node -e \"require('fs').copyFileSync('node_modules/sql.js/dist/sql-wasm.wasm', 'public/sql-wasm.wasm')\"",
    "preview": "node scripts/release.cjs --channel=preview",
    "release": "node scripts/release.cjs --channel=stable",
    "prepare": "husky && npm run copy-wasm"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
