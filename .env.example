NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret key (server-only) — required for calendar OAuth token storage.
# Supabase Dashboard → Project Settings → API Keys → Secret key (sb_secret_…).
# Bypasses RLS; NEVER expose to the client. Legacy service_role key also works.
SUPABASE_SECRET_KEY=

# Push Notifications (Optional)
# Generate VAPID keys using: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

CALENDAR_TOKEN_ENC_KEY=

GOOGLE_CLIENT_ID=<your-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your-client-secret>
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Release channel — controls which changelog entries the in-app "What's New" modal shows.
# 'preview' (default): shows all entries. 'stable': shows only stable releases (≤3).
# Set to 'stable' on production deployments (Vercel env var).
NEXT_PUBLIC_RELEASE_CHANNEL=preview