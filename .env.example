NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret key (server-only) — required for calendar OAuth token storage.
# Supabase Dashboard → Project Settings → API Keys → Secret key (sb_secret_…).
# Bypasses RLS; NEVER expose to the client. Legacy service_role key also works.
SUPABASE_SECRET_KEY=

# Push Notifications (Optional)
# Generate VAPID keys using: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

CALENDAR_TOKEN_ENC_KEY=

GOOGLE_CLIENT_ID=<your-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your-client-secret>
NEXT_PUBLIC_APP_URL=http://localhost:3000

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare Turnstile (Optional) — CAPTCHA on the magic-link sign-in form.
# Required once "Bot and Abuse Protection" is enabled in the Supabase dashboard
# (Authentication → Settings), or signInWithOtp starts failing captcha checks.
# Site key only — the secret key lives in the Supabase dashboard, not here.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Release channel — controls which changelog entries the in-app "What's New" modal shows.
# 'preview' (default): shows all entries. 'stable': shows only stable releases (≤3).
# Set to 'stable' on production deployments (Vercel env var). Also tags Sentry
# events with this as the "environment", so preview/stable errors stay separable.
NEXT_PUBLIC_RELEASE_CHANNEL=preview

# Sentry (Optional) — error monitoring. Leave blank to disable entirely (no-op).
# Create a project at sentry.io (GitHub Student Developer Pack tier) → Client Keys (DSN).
NEXT_PUBLIC_SENTRY_DSN=
# Org/project slugs + an auth token (Settings → Auth Tokens, project:releases scope)
# are only needed in CI to upload source maps — leave blank locally.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=