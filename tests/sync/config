[server]
hosts = 0.0.0.0:5232

[auth]
# Basic auth for testing
type = htpasswd
htpasswd_filename = /config/users
htpasswd_encryption = plain

[storage]
# Override default /var/lib/radicale (owned by root) to use our mounted volume
filesystem_folder = /data

[headers]
# Allow cross-origin requests from the local Next.js dev server
Access-Control-Allow-Origin = http://localhost:3000
Access-Control-Allow-Methods = GET, POST, OPTIONS, PROPFIND, PROPPATCH, REPORT, PUT, MOVE, DELETE, COPY
Access-Control-Allow-Headers = Authorization, Content-Type, Depth, If-Match, If-None-Match, User-Agent, X-Requested-By, Origin
Access-Control-Expose-Headers = ETag, Location, Preference-Applied, DAV, Allow
access-control-allow-credentials = true
